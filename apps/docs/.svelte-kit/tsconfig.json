{
	"compilerOptions": {
		"paths": {
			"$lib": [
				"../src/lib"
			],
			"$lib/*": [
				"../src/lib/*"
			],
			"@yaebal/again": [
				"../../../packages/again/src/index.ts"
			],
			"@yaebal/broadcast": [
				"../../../packages/broadcast/src/index.ts"
			],
			"@yaebal/callback-data": [
				"../../../packages/callback-data/src/index.ts"
			],
			"@yaebal/commands": [
				"../../../packages/commands/src/index.ts"
			],
			"@yaebal/contexts": [
				"../../../packages/contexts/src/index.ts"
			],
			"@yaebal/conversation": [
				"../../../packages/conversation/src/index.ts"
			],
			"@yaebal/core": [
				"../../../packages/core/src/index.ts"
			],
			"create-yaebal": [
				"../../../packages/create-yaebal/src/index.ts"
			],
			"@yaebal/files": [
				"../../../packages/files/src/index.ts"
			],
			"@yaebal/filters": [
				"../../../packages/filters/src/index.ts"
			],
			"@yaebal/fmt": [
				"../../../packages/fmt/src/index.ts"
			],
			"@yaebal/i18n": [
				"../../../packages/i18n/src/index.ts"
			],
			"@yaebal/keyboard": [
				"../../../packages/keyboard/src/index.ts"
			],
			"@yaebal/media-cache": [
				"../../../packages/media-cache/src/index.ts"
			],
			"@yaebal/media-group": [
				"../../../packages/media-group/src/index.ts"
			],
			"@yaebal/morda": [
				"../../../packages/morda/src/index.ts"
			],
			"@yaebal/pagination": [
				"../../../packages/pagination/src/index.ts"
			],
			"@yaebal/panel": [
				"../../../packages/panel/src/index.ts"
			],
			"@yaebal/preview": [
				"../../../packages/preview/src/index.ts"
			],
			"@yaebal/prompt": [
				"../../../packages/prompt/src/index.ts"
			],
			"@yaebal/ratelimiter": [
				"../../../packages/ratelimiter/src/index.ts"
			],
			"@yaebal/router": [
				"../../../packages/router/src/index.ts"
			],
			"@yaebal/runner": [
				"../../../packages/runner/src/index.ts"
			],
			"@yaebal/scenes": [
				"../../../packages/scenes/src/index.ts"
			],
			"@yaebal/session": [
				"../../../packages/session/src/index.ts"
			],
			"@yaebal/split": [
				"../../../packages/split/src/index.ts"
			],
			"@yaebal/test": [
				"../../../packages/test/src/index.ts"
			],
			"@yaebal/throttle": [
				"../../../packages/throttle/src/index.ts"
			],
			"@yaebal/types": [
				"../../../packages/types/src/index.ts"
			],
			"@yaebal/web": [
				"../../../packages/web/src/index.ts"
			],
			"@yaebal/workers": [
				"../../../packages/workers/src/index.ts"
			],
			"yaebal": [
				"../../../packages/yaebal/src/index.ts"
			],
			"$app/types": [
				"./types/index.d.ts"
			]
		},
		"rootDirs": [
			"..",
			"./types"
		],
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"lib": [
			"esnext",
			"DOM",
			"DOM.Iterable"
		],
		"moduleResolution": "bundler",
		"module": "esnext",
		"noEmit": true,
		"target": "esnext"
	},
	"include": [
		"ambient.d.ts",
		"env.d.ts",
		"non-ambient.d.ts",
		"./types/**/$types.d.ts",
		"../vite.config.js",
		"../vite.config.ts",
		"../src/**/*.js",
		"../src/**/*.ts",
		"../src/**/*.svelte",
		"../test/**/*.js",
		"../test/**/*.ts",
		"../test/**/*.svelte",
		"../tests/**/*.js",
		"../tests/**/*.ts",
		"../tests/**/*.svelte"
	],
	"exclude": [
		"../node_modules/**",
		"../src/service-worker.js",
		"../src/service-worker/**/*.js",
		"../src/service-worker.ts",
		"../src/service-worker/**/*.ts",
		"../src/service-worker.d.ts",
		"../src/service-worker/**/*.d.ts"
	]
}