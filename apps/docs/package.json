{
	"name": "@yaebal/docs",
	"version": "0.2.6",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pagefind --site build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"health": "node scripts/check-docs-health.mjs",
		"check:all": "pnpm run health && pnpm run check",
		"generate:api": "node scripts/generate-api-reference.mjs"
	},
	"dependencies": {
		"@yaebal/preview": "workspace:*",
		"@yaebal/test": "workspace:*",
		"interactjs": "^1.10.27",
		"shiki": "^4.3.0",
		"sucrase": "^3.35.1",
		"yaebal": "workspace:*"
	},
	"devDependencies": {
		"@fontsource/ibm-plex-sans": "^5.1.0",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@fontsource/unbounded": "^5.1.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"pagefind": "^1.5.2",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0"
	}
}
