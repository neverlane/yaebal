{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": {
		"ignore": [
			"lib",
			"dist",
			"build",
			".svelte-kit",
			"apps/docs",
			"node_modules",
			".omc",
			"packages/types/schema.json",
			"packages/types/src/telegram.ts",
			"packages/types/scripts/**",
			"packages/contexts/src/generated/**",
			"packages/contexts/scripts/**"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"javascript": {
		"formatter": { "quoteStyle": "double", "semicolons": "always" }
	}
}
