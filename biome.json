{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": {
		"includes": [
			"**",
			"!**/lib",
			"!**/dist",
			"!**/build",
			"!**/.svelte-kit",
			"!**/apps/docs",
			"!**/node_modules",
			"!**/.omc",
			"!**/packages/types/schema.json",
			"!**/packages/types/src/telegram.ts",
			"!**/packages/types/scripts",
			"!**/packages/contexts/src/generated",
			"!**/packages/contexts/scripts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": { "preset": "recommended" }
	},
	"javascript": {
		"formatter": { "quoteStyle": "double", "semicolons": "always" }
	},
	"json": {
		"formatter": { "enabled": false }
	}
}
