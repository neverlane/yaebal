{
	"name": "yaebal-monorepo",
	"version": "0.0.0",
	"private": true,
	"description": "yaebal — Yet Another tElegram Bot Api Library. type-safe, chainable, plugin-first.",
	"type": "module",
	"packageManager": "pnpm@10.34.4",
	"engines": {
		"node": ">=20",
		"pnpm": ">=10 <11"
	},
	"scripts": {
		"build": "pnpm -r --workspace-concurrency=1 --filter \"./packages/*\" run build",
		"typecheck": "pnpm -r run typecheck",
		"test": "pnpm build && pnpm -r --filter \"./packages/*\" run test",
		"dev": "pnpm --filter @yaebal/example-basic run dev",
		"docs:dev": "pnpm --filter @yaebal/docs run dev",
		"docs:check": "pnpm --filter @yaebal/docs run check:all",
		"docs:build": "pnpm --filter @yaebal/docs run build",
		"lint": "biome lint .",
		"lint:fix": "biome check --write .",
		"clean": "pnpm -r exec rm -rf lib node_modules && rm -rf node_modules",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm build && changeset publish",
		"release:all": "node scripts/release.mjs",
		"publish:all": "node scripts/publish-all.mjs",
		"release:notes": "node scripts/auto-release.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@changesets/cli": "^2.31.0",
		"@types/node": "latest",
		"typescript": "^7.0.2"
	},
	"keywords": ["telegram", "telegram-bot", "bot-api", "framework", "typescript", "yaebal"],
	"license": "MIT"
}
