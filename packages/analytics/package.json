{
	"name": "@yaebal/analytics",
	"version": "0.1.0",
	"description": "yaebal analytics — typed ctx.track(event, properties) middleware with pluggable sinks (posthog, plausible, sqlite, clickhouse, http, console), privacy controls, auto-capture, and an in-chat admin surface.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"peerDependencies": {
		"@yaebal/core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest",
		"@yaebal/core": "workspace:*",
		"@yaebal/test": "workspace:*"
	},
	"engines": { "node": ">=20" },
	"keywords": [
		"telegram",
		"telegram-bot",
		"yaebal",
		"analytics",
		"posthog",
		"plausible",
		"sqlite",
		"clickhouse",
		"funnel",
		"gdpr"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/analytics"
	},
	"publishConfig": { "access": "public" }
}
