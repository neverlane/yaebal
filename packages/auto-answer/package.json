{
	"name": "@yaebal/auto-answer",
	"version": "0.1.0",
	"description": "yaebal auto-answer — clears the callback-query loading spinner automatically, no manual answerCallbackQuery call.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"peerDependencies": {
		"@yaebal/core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest",
		"@yaebal/core": "workspace:*",
		"@yaebal/test": "workspace:*"
	},
	"engines": { "node": ">=20" },
	"keywords": ["telegram", "telegram-bot", "yaebal", "callback-query", "auto-answer"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/auto-answer"
	},
	"publishConfig": { "access": "public" }
}
