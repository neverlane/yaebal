{
	"name": "@yaebal/contexts",
	"version": "0.0.4",
	"description": "yaebal contexts — per-update context classes with auto-generated shortcut methods.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": [
		"lib",
		"src"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib",
		"generate": "node scripts/generate.mjs"
	},
	"dependencies": {
		"@yaebal/core": "workspace:*",
		"@yaebal/types": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"telegram",
		"telegram-bot",
		"yaebal",
		"context",
		"codegen"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/contexts"
	},
	"publishConfig": {
		"access": "public"
	}
}
