{
	"name": "@yaebal/conversation",
	"version": "0.0.1",
	"description": "YAEBAL conversation — await-style multi-step dialogs (coroutine, no replay).",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib"
	},
	"dependencies": {
		"@yaebal/core": "workspace:*"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": ["telegram", "telegram-bot", "yaebal", "conversation", "dialog"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/conversation"
	},
	"publishConfig": {
		"access": "public"
	}
}
