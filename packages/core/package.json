{
	"name": "@yaebal/core",
	"version": "0.3.7",
	"description": "yaebal core — type-safe, chainable Telegram Bot API framework.",
	"type": "module",
	"sideEffects": false,
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		},
		"./node": {
			"types": "./lib/node.d.ts",
			"import": "./lib/node.js"
		}
	},
	"files": [
		"lib",
		"src"
	],
	"dependencies": {
		"@yaebal/types": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"telegram",
		"telegram-bot",
		"bot-api",
		"framework",
		"typescript",
		"yaebal"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/core"
	},
	"publishConfig": {
		"access": "public"
	}
}
