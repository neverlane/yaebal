{
	"name": "create-yaebal",
	"version": "0.3.1",
	"description": "scaffold a new yaebal Telegram bot or plugin.",
	"type": "module",
	"bin": {
		"create-yaebal": "./bin/cli.mjs"
	},
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"files": [
		"lib",
		"bin"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js lib/tui/*.test.js"
	},
	"dependencies": {
		"@yaebal/ai": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"telegram",
		"telegram-bot",
		"yaebal",
		"create",
		"scaffold",
		"cli"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/create-yaebal"
	},
	"publishConfig": {
		"access": "public"
	}
}
