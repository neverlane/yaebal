{
	"name": "@yaebal/cron",
	"version": "0.1.0",
	"description": "yaebal cron — typed cron jobs with timezones, retries, catch-up, distributed locks, and a chat-native admin surface.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"peerDependencies": {
		"@yaebal/core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest",
		"@yaebal/core": "workspace:*",
		"@yaebal/test": "workspace:*"
	},
	"engines": { "node": ">=20" },
	"keywords": ["telegram", "telegram-bot", "yaebal", "cron", "scheduler"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/cron"
	},
	"publishConfig": { "access": "public" }
}
