{
	"name": "@yaebal/files",
	"version": "0.1.1",
	"description": "yaebal files plugin — ctx.files: inspect, link, stream and download telegram files; local Bot API server aware.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"peerDependencies": {
		"@yaebal/core": "workspace:*"
	},
	"dependencies": {
		"@yaebal/types": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest",
		"@yaebal/core": "workspace:*",
		"@yaebal/test": "workspace:*"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": ["telegram", "telegram-bot", "yaebal", "files", "download"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/files"
	},
	"publishConfig": {
		"access": "public"
	}
}
