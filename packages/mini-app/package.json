{
	"name": "@yaebal/mini-app",
	"version": "0.0.1",
	"description": "yaebal mini-app — Telegram Mini Apps protocol: ctx.miniApp.validate(initData), a typed initData parser, web_app_data helpers, and a WebAppInfo/deep-link url generator.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"dependencies": {
		"@yaebal/core": "workspace:*",
		"@yaebal/types": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest",
		"@yaebal/test": "workspace:*"
	},
	"engines": { "node": ">=20" },
	"keywords": ["telegram", "telegram-bot", "yaebal", "mini-app", "web-app", "webapp", "init-data"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/mini-app"
	},
	"publishConfig": { "access": "public" }
}
