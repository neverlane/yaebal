{
	"name": "@yaebal/mini-app",
	"version": "0.1.1",
	"description": "yaebal mini-app — the Telegram Mini Apps server protocol: HMAC + Ed25519 (third-party) initData validation, a typed parser and test signer, an Authorization: tma header helper, answerWebAppQuery, and a WebAppInfo/deep-link url generator.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"peerDependencies": {
		"@yaebal/core": "workspace:*"
	},
	"dependencies": {
		"@yaebal/types": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest",
		"@yaebal/core": "workspace:*",
		"@yaebal/test": "workspace:*"
	},
	"engines": { "node": ">=20" },
	"keywords": [
		"telegram",
		"telegram-bot",
		"yaebal",
		"mini-app",
		"web-app",
		"webapp",
		"init-data",
		"ed25519",
		"tma"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/mini-app"
	},
	"publishConfig": { "access": "public" }
}
