{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./lib",
		"composite": true,
		"types": ["node"],
		"jsx": "react-jsx",
		"jsxImportSource": "@yaebal/morda",
		"paths": {
			"@yaebal/morda/jsx-runtime": ["./src/jsx/jsx-runtime.ts"]
		}
	},
	"references": [
		{ "path": "../core" },
		{ "path": "../keyboard" },
		{ "path": "../callback-data" },
		{ "path": "../sklad" }
	],
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
