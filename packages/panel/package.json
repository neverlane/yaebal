{
	"name": "@yaebal/panel",
	"version": "0.1.0",
	"description": "yaebal panel — an operator panel: view chats, handoff, reply and search from the browser.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		},
		"./serve": {
			"types": "./lib/serve.d.ts",
			"import": "./lib/serve.js"
		},
		"./sqlite": {
			"types": "./lib/sqlite.d.ts",
			"import": "./lib/sqlite.js"
		},
		"./sklad": {
			"types": "./lib/sklad.d.ts",
			"import": "./lib/sklad.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"peerDependencies": {
		"@yaebal/core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest",
		"@yaebal/core": "workspace:*"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"telegram",
		"telegram-bot",
		"yaebal",
		"panel",
		"dashboard",
		"live-chat",
		"handoff",
		"helpdesk"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/panel"
	},
	"publishConfig": {
		"access": "public"
	}
}
