{
	"name": "@yaebal/panel",
	"version": "0.0.3",
	"description": "yaebal panel — an operator panel: view chats and reply from the browser.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		},
		"./serve": {
			"types": "./lib/serve.d.ts",
			"import": "./lib/serve.js"
		},
		"./sqlite": {
			"types": "./lib/sqlite.d.ts",
			"import": "./lib/sqlite.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib"
	},
	"dependencies": {
		"@yaebal/core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": ["telegram", "telegram-bot", "yaebal", "panel", "dashboard", "live-chat"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/panel"
	},
	"publishConfig": {
		"access": "public"
	}
}
