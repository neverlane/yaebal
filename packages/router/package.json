{
	"name": "@yaebal/router",
	"version": "0.1.0",
	"description": "yaebal file-based routing — typed define*() route files, load-time validation, nested guards, and dev hot-reload.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"dependencies": {
		"@yaebal/types": "workspace:*"
	},
	"peerDependencies": {
		"@yaebal/core": "workspace:*",
		"@yaebal/commands": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@yaebal/commands": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "latest",
		"@yaebal/commands": "workspace:*",
		"@yaebal/core": "workspace:*",
		"@yaebal/test": "workspace:*"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"telegram",
		"telegram-bot",
		"yaebal",
		"router",
		"file-based-routing",
		"hot-reload"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/router"
	},
	"publishConfig": {
		"access": "public"
	}
}
