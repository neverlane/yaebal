{
	"name": "@yaebal/session",
	"version": "0.1.0",
	"description": "yaebal session plugin — typed per-chat/per-user state: dirty-checked saves, lazy loading, multi-session, migrations, ttl fields, pluggable storage.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"dependencies": {
		"@yaebal/core": "workspace:*",
		"@yaebal/sklad": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": ["telegram", "telegram-bot", "yaebal", "session", "storage"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/session"
	},
	"publishConfig": {
		"access": "public"
	}
}
