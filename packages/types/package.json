{
	"name": "@yaebal/types",
	"version": "10.1.2",
	"description": "yaebal types — full Telegram Bot API types, code-generated from the schema.",
	"type": "module",
	"sideEffects": false,
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": [
		"lib",
		"src"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js && node --test scripts/*.test.mjs",
		"test:parser": "node --test scripts/*.test.mjs",
		"generate": "node scripts/generate.mjs",
		"update-schema": "node scripts/update-schema.mjs"
	},
	"devDependencies": {
		"@types/node": "latest"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"telegram",
		"telegram-bot",
		"yaebal",
		"types",
		"bot-api"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/types"
	},
	"publishConfig": {
		"access": "public"
	}
}
