{
	"name": "@yaebal/web",
	"version": "0.0.1",
	"description": "yaebal web — run your bot on edge/web runtimes (cloudflare workers, deno, bun) via webhooks.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib"
	},
	"dependencies": {
		"@yaebal/core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"telegram",
		"telegram-bot",
		"yaebal",
		"webhook",
		"edge",
		"cloudflare-workers",
		"deno",
		"bun"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/web"
	},
	"publishConfig": {
		"access": "public"
	}
}
