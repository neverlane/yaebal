{
	"name": "@yaebal/workers",
	"version": "0.1.0",
	"description": "yaebal workers — a typed worker_threads pool: queueing, timeouts, aborts, crash recovery, zero-copy transfers.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		},
		"./plugin": {
			"types": "./lib/plugin.d.ts",
			"import": "./lib/plugin.js"
		}
	},
	"sideEffects": false,
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"peerDependencies": {
		"@yaebal/core": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@yaebal/core": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "latest",
		"@yaebal/core": "workspace:*"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"telegram",
		"telegram-bot",
		"yaebal",
		"worker",
		"worker-threads",
		"pool",
		"thread-pool"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/workers"
	},
	"publishConfig": {
		"access": "public"
	}
}
