{
	"name": "yaebal",
	"version": "0.0.7",
	"description": "yaebal — batteries-included Telegram Bot API framework: core + auto-generated contexts + the common plugins, one import.",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": ["lib", "src"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test lib/*.test.js"
	},
	"dependencies": {
		"@yaebal/core": "workspace:*",
		"@yaebal/contexts": "workspace:*",
		"@yaebal/keyboard": "workspace:*",
		"@yaebal/callback-data": "workspace:*",
		"@yaebal/filters": "workspace:*",
		"@yaebal/fmt": "workspace:*",
		"@yaebal/session": "workspace:*",
		"@yaebal/i18n": "workspace:*",
		"@yaebal/web": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "latest"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": ["telegram", "telegram-bot", "bot-api", "framework", "typescript", "yaebal"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/neverlane/yaebal",
		"directory": "packages/yaebal"
	},
	"publishConfig": {
		"access": "public"
	}
}
